# AgriGPT Environment Variables
# Copy this file to .env and fill in your values:
#   cp backend/env.example backend/.env

# Required for LLM (text + vision)
GROQ_API_KEY=your_groq_api_key

# Optional – Weather in header
OPENWEATHER_API_KEY=your_openweather_api_key

# LangSmith tracing (get API key from smith.langchain.com → Settings → API Keys, NOT OpenAI)
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key
# LANGCHAIN_API_KEY=lsv2_pt_...  # alternative; LANGSMITH_API_KEY preferred
LANGCHAIN_PROJECT=agrigpt

# Pinecone for RAG (falls back to FAISS if unset)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=agrigpt-subsidies

# Redis for persistent chat memory (falls back to in-memory if unset)
# Local: redis://localhost:6379/0  |  Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
